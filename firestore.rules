rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Issues: anyone can read (public map); only signed-in users can create/update.
    match /issues/{id} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Profiles: public-readable; a user may only write their own profile.
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Notifications: only the recipient can read/mark-read; any signed-in
    // user may create one (e.g. an authority notifying a reporter).
    match /notifications/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
  }
}
