# ---- Server ----
PORT=8080
CORS_ORIGIN=http://localhost:5173

# ---- Gemini ----
# Use a STANDARD API key from AI Studio (starts with "AIzaSy"), NOT an
# ephemeral "AQ." token (those expire in ~30 min).
# https://aistudio.google.com -> "Get API key" -> "Create API key"
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ---- Firebase Admin (service account) ----
# Firebase console -> Project settings -> Service accounts ->
# "Generate new private key" -> save as backend/serviceAccountKey.json (gitignored).
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=junkcivicsense

# NOTE: Firebase Storage is not enabled (Blaze-only), so images are stored as
# compressed base64 in Firestore for the MVP. No storage bucket needed.
